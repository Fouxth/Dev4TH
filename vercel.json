{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/socket.io/:path*",
      "destination": "https://dev4th.duckdns.org/socket.io/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://dev4th.duckdns.org/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://dev4th.duckdns.org/uploads/:path*"
    }
  ]
}
